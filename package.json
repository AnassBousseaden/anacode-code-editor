{
	"name": "@anacode/code-editor",
	"version": "0.0.1",
	"description": "A self-contained, reusable multi-file code editor built on Monaco.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepare": "npm run package",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css",
		"./file-system": {
			"types": "./dist/file-system.d.ts",
			"svelte": "./dist/file-system.js",
			"default": "./dist/file-system.js"
		},
		"./persistence": {
			"types": "./dist/persistence.d.ts",
			"svelte": "./dist/persistence.js",
			"default": "./dist/persistence.js"
		},
		"./session": {
			"types": "./dist/session.d.ts",
			"svelte": "./dist/session.js",
			"default": "./dist/session.js"
		},
		"./state": {
			"types": "./dist/state.d.ts",
			"svelte": "./dist/state.js",
			"default": "./dist/state.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"svelte": "./dist/config.js",
			"default": "./dist/config.js"
		},
		"./icons": {
			"types": "./dist/icons.d.ts",
			"svelte": "./dist/icons.js",
			"default": "./dist/icons.js"
		},
		"./shared": {
			"types": "./dist/shared.d.ts",
			"svelte": "./dist/shared.js",
			"default": "./dist/shared.js"
		},
		"./*.svelte": {
			"types": "./dist/*.svelte.d.ts",
			"svelte": "./dist/*.svelte"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"svelte": "./dist/*.js",
			"default": "./dist/*.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"@lucide/svelte": "^1.0.0",
		"bits-ui": "^2.0.0",
		"mode-watcher": "^1.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.0.0"
	},
	"dependencies": {
		"@iconify-json/vscode-icons": "^1.2.51",
		"@iconify/svelte": "^5.0.0",
		"clsx": "^2.1.1",
		"graphology": "^0.26.0",
		"graphology-dag": "^0.4.1",
		"graphology-traversal": "^0.3.1",
		"immer": "^11.1.3",
		"jszip": "^3.10.1",
		"lodash": "^4.17.23",
		"monaco-editor": "^0.55.1",
		"paneforge": "^1.0.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@fontsource-variable/geist": "^5.2.9",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/package": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.3.0",
		"@types/lodash": "^4.17.23",
		"@types/node": "^22.0.0",
		"bits-ui": "^2.18.1",
		"graphology-types": "^0.24.8",
		"mode-watcher": "^1.0.0",
		"publint": "^0.3.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.2",
		"vitest": "^4.0.18"
	}
}
